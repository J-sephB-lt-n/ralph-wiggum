{
  "$schema": "https://opencode.ai/config.json",

  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "allow",
    "task": "allow",
    "skill": "allow",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "deny",
    "websearch": "deny",
    "codesearch": "deny",
    "external_directory": "allow",
    "doom_loop": "deny"
  },

  "provider": {
    "gaiss": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "gaiss",
      "options": {
        "baseURL": "{env:OPENAI_BASE_URL}",
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "bedrock.anthropic.claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 Thinking",
          "options": {
            "thinking": {
              "type": "enabled",
              "budget_tokens": 12000
            }
          },
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "cost": {
            "input": 3,
            "output": 15
          }
        },
        "bedrock.anthropic.claude-opus-4-6": {
          "name": "Claude Opus 4.6 Thinking",
          "options": {
            "thinking": {
              "type": "enabled",
              "budget_tokens": 12000
            }
          },
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "cost": {
            "input": 5.5,
            "output": 27.5
          }
        }
      }
    }
  },
  "model": "gaiss/bedrock.anthropic.claude-sonnet-4-6"
}
